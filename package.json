{
  "name": "swiftmask",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "WEBKIT_DISABLE_COMPOSITING_MODE=1 tauri",
    "tauri:build:cachy": "WEBKIT_DISABLE_COMPOSITING_MODE=1 NO_STRIP=true tauri build",
    "gen:models": "cargo run --manifest-path src-tauri/Cargo.toml --bin gen_model_registry",
    "gen:models:check": "cargo run --manifest-path src-tauri/Cargo.toml --bin gen_model_registry -- --check",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck:e2e": "tsc --project tsconfig.e2e.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "^1.52.0",
    "@tauri-apps/cli": "^2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.10"
  }
}
