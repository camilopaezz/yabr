{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SwiftMask",
  "version": "0.9.0-beta.1",
  "identifier": "com.camilo.swiftmask",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SwiftMask",
        "width": 1100,
        "height": 720,
        "minWidth": 640,
        "minHeight": 420,
        "decorations": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*"],
          "requireLiteralLeadingDot": false
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "version": "0.9.0.1"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCRDBEMzUxMjEwRUQwMApSV1FBN1JBU05RMjlCc3JXd2FwT2VZWkdYRG81K09tRmk4RzBHL0RWOGVxUUZQRU80Sm1tS1c3SAo=",
      "endpoints": [
        "https://github.com/camilopaezz/SwiftMask/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
